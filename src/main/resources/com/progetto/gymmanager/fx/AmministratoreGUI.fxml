<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<VBox alignment="TOP_CENTER" spacing="15.0" styleClass="root" stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.progetto.gymmanager.view.fx.AmministratoreGUIController">
    <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>

    <Label text="PANNELLO DI AMMINISTRAZIONE" style="-fx-font-size: 26px; -fx-text-fill: #deff9a; -fx-font-weight: bold;"/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1a1a;">
        <Tab text="Gestione Istruttori">
            <HBox spacing="20" alignment="CENTER">
                <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #333; -fx-padding: 20; -fx-background-radius: 10;">
                    <Label text="Staff Attuale (Seleziona per eliminare)" style="-fx-text-fill: white;"/>
                    <ListView fx:id="istruttoriListView" VBox.vgrow="ALWAYS"/>
                    <Button text="LICENZIA ISTRUTTORE" onAction="#handleEliminaIstruttore" maxWidth="Infinity" style="-fx-background-color: #ff4444; -fx-text-fill: white;"/>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #333; -fx-padding: 20; -fx-background-radius: 10;" alignment="TOP_CENTER">
                    <Label text="Assumi Nuovo Istruttore" style="-fx-text-fill: white;"/>
                    <TextField fx:id="nickIstruttore" promptText="Nickname"/>
                    <TextField fx:id="emailIstruttore" promptText="Email"/>
                    <PasswordField fx:id="passIstruttore" promptText="Password"/>
                    <DatePicker fx:id="nascitaIstruttore" promptText="Data Nascita" maxWidth="Infinity"/>
                    <TextField fx:id="indirizzoIstruttore" promptText="Indirizzo"/>
                    <TextField fx:id="telefonoIstruttore" promptText="Telefono"/>
                    <Button text="CREA ACCOUNT" onAction="#handleCreaIstruttore" maxWidth="Infinity" style="-fx-background-color: #11caa0; -fx-text-fill: black;"/>
                </VBox>
            </HBox>
        </Tab>

        <Tab text="Gestione Shop &amp; Fornitori">
            <HBox spacing="15" alignment="CENTER">
                <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #333; -fx-padding: 20; -fx-background-radius: 10;">
                    <Label text="Aggiungi Prodotto" style="-fx-text-fill: white;"/>
                    <TextField fx:id="nomeProdottoField" promptText="Nome Prodotto"/>
                    <TextField fx:id="prezzoProdottoField" promptText="Prezzo (es. 19.99)"/>
                    <Button text="INSERISCI IN CATALOGO" onAction="#handleAggiungiProdotto" style="-fx-background-color: #deff9a; -fx-text-fill: black;"/>
                </VBox>

                <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #333; -fx-padding: 20; -fx-background-radius: 10;">
                    <Label text="Gestione Sconti" style="-fx-text-fill: white;"/>
                    <ListView fx:id="scontiListView" prefHeight="120" VBox.vgrow="ALWAYS"/>
                    <Button text="ELIMINA SCONTO" onAction="#handleEliminaSconto" style="-fx-background-color: #ff4444; -fx-text-fill: white;" maxWidth="Infinity"/>

                    <Label text="Nuovo Sconto" style="-fx-text-fill: white; -fx-padding: 10 0 0 0;"/>
                    <TextField fx:id="codiceScontoField" promptText="Codice (es. SUMMER)"/>
                    <TextField fx:id="percentualeScontoField" promptText="Percentuale (%)"/>
                    <Button text="CREA SCONTO" onAction="#handleCreaSconto" style="-fx-background-color: #deff9a; -fx-text-fill: black;" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #333; -fx-padding: 20; -fx-background-radius: 10;">
                    <Label text="Ordina Rifornimento" style="-fx-text-fill: white;"/>
                    <TextField fx:id="fornitoreField" promptText="Nome Fornitore (Email)"/>
                    <TextField fx:id="prodottoRifornimentoField" promptText="Prodotto da Ordinare"/>
                    <TextField fx:id="quantitaRifornimentoField" promptText="Quantità"/>
                    <Button text="INVIA ORDINE" onAction="#handleOrdinaRifornimento" style="-fx-background-color: #ffaa00; -fx-text-fill: black;"/>
                </VBox>
            </HBox>
        </Tab>

        <Tab text="Invia Comunicazione">
            <VBox spacing="15" alignment="CENTER">
                <padding><Insets top="20" bottom="20" left="40" right="40"/></padding>
                <Label text="Invia una notifica push a gruppi di utenti:" style="-fx-font-size: 18px; -fx-text-fill: white;"/>

                <ComboBox fx:id="targetComboBox" promptText="Seleziona Destinatari" prefWidth="250">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="TUTTI" />
                            <String fx:value="ABBONATI" />
                            <String fx:value="ISTRUTTORI" />
                        </FXCollections>
                    </items>
                </ComboBox>

                <TextArea fx:id="comunicazioneArea" promptText="Scrivi qui il tuo messaggio..." VBox.vgrow="ALWAYS" wrapText="true"/>
                <Button text="INVIA COMUNICAZIONE" onAction="#handleInviaComunicazione" prefWidth="250" style="-fx-background-color: #11caa0; -fx-text-fill: black;"/>
            </VBox>
        </Tab>
    </TabPane>

    <Button text="ESCI / LOGOUT" onAction="#handleLogout" prefWidth="200" prefHeight="40" style="-fx-background-color: #ff4444; -fx-text-fill: white;"/>
</VBox>